generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id               String   @id @default(cuid())
  name             String   @default("Faisal Ramdhani")
  professionalTitle String   @default("Full-Stack Developer")
  aboutText        String   @db.Text
  cvLink           String?
  aboutPhoto       String?
  instagramLink    String?
  githubLink       String?
  linkedinLink     String?
  updatedAt        DateTime @updatedAt
}

model Skill {
  id          String   @id @default(cuid())
  name        String   // e.g., "HTML", "React", "MySQL"
  category    String?  // e.g., "Frontend", "Backend", "Design"
  description String?  @db.Text
  imageUrl    String?  // For custom brand icons
  link        String?  // URL to tool website
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  imageUrl    String?  // If null, frontend shows aesthetic Lando-themed placeholder
  demoLink    String?
  githubLink  String?
  sourceLink  String?  // New field requested
  category    String?  // Frontend, Backend, Fullstack
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  jobTitle    String
  company     String
  duration    String   // e.g., "Jan 2023 - Present"
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certificate {
  id          String   @id @default(cuid())
  name        String
  issuer      String
  date        String
  imageUrl    String?
  link        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hashed via bcrypt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  degree      String
  institution String
  duration    String
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  text      String   @db.Text
  author    String
  role      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
